{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "observation.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["timestamp", "screenshot_id", "ui_elements", "audio_events", "meta"],
  "properties": {
    "timestamp": {"type": "string"},
    "screenshot_id": {"type": "string"},
    "ui_elements": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["element_id", "role", "text", "attributes"],
        "properties": {
          "element_id": {"type": "string"},
          "role": {"type": "string"},
          "text": {"type": "string"},
          "attributes": {"type": "object"}
        }
      }
    },
    "audio_events": {
      "type": "array",
      "items": {"type": "object"}
    },
    "meta": {"type": "object"}
  }
}

