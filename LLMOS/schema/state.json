{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "state.json",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "seed",
    "fidelity",
    "template",
    "windows",
    "page",
    "ui_elements",
    "filesystem",
    "random_seed"
  ],
  "properties": {
    "seed": {"type": "integer"},
    "fidelity": {"type": "string"},
    "template": {"type": "string"},
    "windows": {"type": "array"},
    "page": {"type": "string"},
    "ui_elements": {"type": "array"},
    "forms": {"type": "object"},
    "filesystem": {"type": "object"},
    "clipboard": {"type": "string"},
    "network_logs": {"type": "array"},
    "processes": {"type": "array"},
    "random_seed": {"type": "integer"}
  }
}

